# ===================================
# REQUIRED - Supabase Configuration
# ===================================
# Get these values from your Supabase project dashboard:
# https://app.supabase.com/project/YOUR_PROJECT/settings/api
#
# Performans: Tarayıcı/istemci için NEXT_PUBLIC_* yeterli. Sunucu tarafında
# (API routes, Prisma vb.) doğrudan Postgres kullanıyorsanız, bağlantı havuzu
# (pooler) kullanın: Database > Connection string > "Use connection pooling"
# (port 6543 / ...pooler.supabase.com). Böylece metadata/timezone overhead azalır.

NEXT_PUBLIC_SUPABASE_URL=https://itvrvouaxcutpetyzhvg.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9....

# Service role key (SERVER ONLY - never expose to client).
# Required for: Admin demo seed, Edge Function proxy.
# Supabase Dashboard > Project Settings > API > service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=

# ===================================
# OPTIONAL - Email Service (Resend)
# ===================================
# Get your API key from: https://resend.com/api-keys
# Required for: Demo requests, support tickets, password reset emails
# If not set: Email features will be disabled
#
# Resend'de gonderici domain dogrulamasi zorunludur: https://resend.com/domains
# Dogruladiginiz domain ile gonderici adresi (ornek: ModulusTech <noreply@yourdomain.com>)

RESEND_API_KEY=
RESEND_FROM_EMAIL=ModulusTech <noreply@yourdomain.com>

# ===================================
# OPTIONAL - OpenAI API
# ===================================
# Get your API key from: https://platform.openai.com/api-keys
# Required for: AI-powered features (Accounting AI, CRM AI, Finance Robot)
# If not set: AI features will show errors or fallback to basic functionality

OPENAI_API_KEY=

# ===================================
# OPTIONAL - AI Service URL
# ===================================
# URL for the Python-based AI cash flow prediction service
# Default: http://localhost:8000 (for local development)
# For production: Set this to your deployed AI service URL

NEXT_PUBLIC_AI_SERVICE_URL=http://localhost:8000

# ===================================
# OPTIONAL - Site Configuration
# ===================================
# Base URL for your site (used for metadata and links)
# Default: https://modulus.tech

NEXT_PUBLIC_SITE_URL=https://modulus.tech

# ===================================
# OPTIONAL - Build Configuration
# ===================================
# Disable Next.js telemetry
# Default: 1

NEXT_TELEMETRY_DISABLED=1

# ===================================
# AppointFlow module (autonomous WhatsApp + Google Calendar agent)
# ===================================
# All AppointFlow env vars use the APPTFLOW_ / LEMON_ / GOOGLE_ / WHATSAPP_
# prefixes. The module only boots if these are set — the rest of the ERP
# continues to work without them.

# Shared secrets — generate with: openssl rand -base64 48
APPTFLOW_WEBHOOK_SECRET=
APPTFLOW_CRON_SECRET=

# Public base URL used by the agent for redirect/callback URLs.
APPTFLOW_PUBLIC_URL=https://modulusaas.com

# Orchestrator edge function URL — defaults to
#   {NEXT_PUBLIC_SUPABASE_URL}/functions/v1/apptflow-orchestrator
# Only set if you deploy the orchestrator separately.
# APPTFLOW_ORCHESTRATOR_URL=

# Default currency for checkout when the tenant locale has no preference.
APPTFLOW_DEFAULT_CURRENCY=USD

# Minimum gross margin enforced by the Pricing Agent (0..1). Default 0.10.
APPTFLOW_MIN_MARGIN=0.10

# FX provider used by the nightly fx-sync cron. Default: open.er-api.com
# (free, key-less). Also supported: exchangerate-api.com v6, currencylayer.
APPTFLOW_FX_PROVIDER_URL=https://open.er-api.com/v6/latest/USD
# APPTFLOW_FX_PROVIDER_API_KEY=

# ---- Billing: Lemon Squeezy (Merchant of Record) ----
# Dashboard: https://app.lemonsqueezy.com/settings/api
LEMON_SQUEEZY_API_KEY=
LEMON_SQUEEZY_STORE_ID=
LEMON_SQUEEZY_WEBHOOK_SECRET=

# Variant IDs for each AppointFlow tier + billing cycle. Create three
# Subscription products (Starter/Pro/Business) in Lemon, each with Monthly
# and Yearly variants, then paste the numeric variant IDs below.
LEMON_VARIANT_STARTER_MONTHLY=
LEMON_VARIANT_STARTER_YEARLY=
LEMON_VARIANT_PRO_MONTHLY=
LEMON_VARIANT_PRO_YEARLY=
LEMON_VARIANT_BUSINESS_MONTHLY=
LEMON_VARIANT_BUSINESS_YEARLY=

# ---- WhatsApp Cloud API ----
# Dashboard: https://developers.facebook.com/apps/
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# ---- Google Calendar OAuth ----
# Console: https://console.cloud.google.com/apis/credentials
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://modulusaas.com/api/apptflow/calendar/google/callback

# ---- OpenAI (used by the WhatsApp Messaging Agent) ----
# Defaults to OPENAI_API_KEY above if not set; override with a dedicated key
# to isolate AppointFlow spend.
OPENAI_MODEL=gpt-4o-mini
